generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AppConfig {
  id                    String   @id @default("singleton")
  googleClientId        String?
  googleClientSecret    String?
  microsoftClientId     String?
  microsoftClientSecret String?
  microsoftTenantId     String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  isApproved    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  calendarConnections CalendarConnection[]
  calendarEvents      CalendarEvent[]
  settings            UserSettings?
  tones               Tone[]
  formats             Format[]
}

model UserSettings {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  anthropicApiKey         String?
  openaiApiKey            String?
  masterCalendarProvider  String    @default("google")
  masterCalendarColor     String?
  calendarId              String?
  syncInterval            Int       @default(15)
  calendarStartHour       Int       @default(0)
  calendarEndHour         Int       @default(24)
  calendarSyncedAt        DateTime?
  availabilitySchedule    Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tone {
  id           String   @id @default(cuid())
  userId       String
  name         String
  instructions String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Format {
  id           String   @id @default(cuid())
  userId       String
  name         String
  instructions String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CalendarConnection {
  id                       String    @id @default(cuid())
  userId                   String
  sourceType               String    // 'microsoft' | 'ical'
  sourceCalendarId         String?
  sourceCalendarName       String
  icalUrl                  String?
  targetGoogleCalendarId   String?
  targetGoogleCalendarName String
  lastSyncedAt             DateTime?
  syncToken                String?
  deltaToken               String?
  syncMode                 String    @default("read_only")
  color                    String?
  watchChannelId           String?
  watchResourceId          String?
  watchExpiration          DateTime?
  isActive                 Boolean   @default(true)
  syncErrors               Int       @default(0)
  lastErrorAt              DateTime?
  lastErrorMessage         String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventMappings EventMapping[]
}

model EventMapping {
  id                 String    @id @default(cuid())
  connectionId       String
  sourceEventId      String
  googleEventId      String?
  sourceLastModified DateTime?
  googleLastModified DateTime?
  syncDirection      String    @default("source_to_google")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  connection CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, sourceEventId])
}

model CalendarEvent {
  id         String   @id @default(cuid())
  userId     String
  externalId String
  source     String   // "master" | CalendarConnection.id
  title      String
  startAt    DateTime
  endAt      DateTime
  allDay     Boolean  @default(false)
  location   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source, externalId])
  @@index([userId, startAt])
}

model PendingBooking {
  id              String    @id @default(cuid())
  guestName       String
  guestEmail      String
  guestCompany    String
  subject         String
  note            String?
  location        String    @default("online")
  address         String?
  proposedStart   DateTime
  proposedEnd     DateTime
  durationMinutes Int
  status          String    @default("pending")
  teamsLink       String?
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?
}
